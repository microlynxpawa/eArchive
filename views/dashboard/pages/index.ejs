  &lt;li&gt;&lt;i class="icofont icofont-maximize full-card font-white"&gt;&lt;/i&gt;&lt;/li&gt;
  &lt;li&gt;&lt;i class="icofont icofont-minus minimize-card font-white"&gt;&lt;/i&gt;&lt;/li&gt;
  &lt;li&gt;&lt;i class="icofont icofont-refresh reload-card font-white"&gt;&lt;/i&gt;&lt;/li&gt;
  &lt;li&gt;&lt;i class="icofont icofont-error close-card font-white"&gt; &lt;/i&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;div class="card-body p-0"&gt;
&lt;div class="revenue-chart" id="revenue-chart"&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;</code></pre>
          </div>
        </div>
      </div>
      <div class="card total-investment">
        <div class="card-header pb-0">
          <div class="d-flex justify-content-between">
            <div class="flex-grow-1">
              <p class="square-after f-w-600 header-text-primary">History<i class="fa fa-circle"> </i></p>
              <h4 class="mb-2">Latest Login History</h4>
              <h4>
                <% if (user && user.AuditLogs && user.AuditLogs.length > 0) { %>
                  <p>Last Login Time: <%= user.AuditLogs[0].loginTime %></p>
                  <p>Last Logout Time: <%= user.AuditLogs[0].logoutTime %></p>
                <% } else { %>
                  <p>No login or logout time data available.</p>
                <% } %>
              </h4>
              
            </div>
            <div class="setting-list">
              <ul class="list-unstyled setting-option">
                <li>
                  <div class="setting-light"><i class="icon-layout-grid2"></i></div>
                </li>
                <li><i class="icofont icofont-maximize full-card font-white"></i></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xxl-3 col-xl-4 col-md-6 dash-30 box-col-35">
      <div class="card our-user">
        <div class="card-header pb-0">
          <div class="d-flex justify-content-between">
            <div class="flex-grow-1">
              <p class="square-after f-w-600 header-text-primary">Information<i class="fa fa-circle"></i></p>
              <h4>Guide Lines</h4>
            </div>
            <div class="setting-list">
              <ul class="list-unstyled setting-option">
                <li>
                  <div class="setting-light"><i class="icon-layout-grid2"></i></div>
                </li>
                <li><i class="icofont icofont-maximize full-card font-white"></i></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div class="user-chart">
            <div id="user-chart"></div>
          </div>
          <ul id="admin-messages-dashboard">
            <!-- Admin messages will be injected here -->
          </ul>
        </div>
      </div>

      <!-- Modal for long messages -->
      <div class="modal fade" id="adminMessageModal" tabindex="-1" aria-labelledby="adminMessageModalLabel" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="adminMessageModalLabel">Information</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="adminMessageModalBody"></div>
          </div>
        </div>
      </div>

      <script>
      // Weather fetch using wttr.in (no API key required)
function updateWeatherSection() {
  fetch('https://wttr.in/?format=j1')
    .then(res => res.json())
    .then(data => {
      // Get current condition
      const current = data.current_condition && data.current_condition[0];
      if (!current) throw new Error('No weather data');
      const tempC = current.temp_C;
      const desc = current.weatherDesc[0].value;
      const iconUrl = current.weatherIconUrl[0].value;
      // Set temperature
      document.getElementById('weather-temp').innerHTML = `<span>${tempC}<sup><i class='fa fa-circle-o f-10'></i></sup>C </span>`;
      // Set icon based on description
      let iconHtml = '';
      const descLower = desc.toLowerCase();
      if (descLower.includes('sun') || descLower.includes('clear')) {
        iconHtml = `<i class='icofont icofont-sun font-primary'></i>`;
      } else if (descLower.includes('cloud')) {
        iconHtml = `<i class='icofont icofont-cloud font-primary'></i>`;
      } else if (descLower.includes('rain') || descLower.includes('shower') || descLower.includes('thunder')) {
        iconHtml = `<i class='icofont icofont-rainy font-primary'></i>`;
      } else {
        iconHtml = '';
      }
      document.getElementById('weather-icon').innerHTML = iconHtml;
      // Set description
      document.getElementById('weather-desc').textContent = desc;
      // Set a dynamic message based on temperature
      let msg = '';
      const t = parseInt(tempC, 10);
      if (t >= 30) msg = 'Stay hydrated! It’s a hot day.';
      else if (t >= 20) msg = 'Great weather for a walk!';
      else if (t >= 10) msg = 'A bit chilly, dress warm.';
      else msg = 'Brrr! Keep warm today.';
      document.getElementById('weather-message').textContent = msg;
    })
    .catch(() => {
      // Fallback to static
      document.getElementById('weather-temp').innerHTML = `<span>28<sup><i class='fa fa-circle-o f-10'></i></sup>C </span>`;
      document.getElementById('weather-icon').innerHTML = `<i class='icofont icofont-sun font-primary'></i>`;
      document.getElementById('weather-desc').textContent = 'Sunny Day';
      document.getElementById('weather-message').textContent = 'Beautiful Sunny Day Walk';
    });
}
updateWeatherSection();
      // Fetch and display admin messages on dashboard
      function fetchDashboardAdminMessages() {
        $.get('/admin/messages', function(data) {
          if (data.success) {
            const list = $('#admin-messages-dashboard');
            list.empty();
            if (data.messages.length === 0) {
              list.append('<li><span>No information from admin yet.</span></li>');
            } else {
              data.messages.forEach(msg => {
                const shortMsg = msg.message.length > 80 ? msg.message.substring(0, 80) + '...' : msg.message;
                const needsModal = msg.message.length > 80;
                list.append(`
                  <li>
                    <span class="f-w-200 font-primary f-12">News </span>
                    <span class="f-w-100">${shortMsg}</span>
                    ${needsModal ? `<button class="btn btn-link p-0 view-full-msg" data-msg="${encodeURIComponent(msg.message)}">Read more</button>` : ''}
                  </li>
                `);
              });
            }
          }
        });
      }

      // Show modal for long messages
      $('#admin-messages-dashboard').on('click', '.view-full-msg', function() {
        const msg = decodeURIComponent($(this).data('msg'));
        $('#adminMessageModalBody').text(msg);
        $('#adminMessageModal').modal('show');
      });

      // Initial fetch
      fetchDashboardAdminMessages();
      </script>
    </div>
  </div>
</div>

<%- contentFor("pageHeader") %>
  <%- include('../components/page-title.ejs', {title: 'Dashboard' }) %>