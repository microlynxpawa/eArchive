                <li class="dot-small bg-info dot-5"></li>
                <li class="dot-big bg-info dot-6"></li>
                <li class="dot-small bg-primary dot-7"></li>
                <li class="semi-medium bg-primary dot-8"></li>
                <li class="dot-big bg-info dot-9"></li>
