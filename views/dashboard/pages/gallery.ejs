</style>
<style>
  /* Simple modal styling */
  #searchResultsModal {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.6);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
  }

  #filesModalContent {
    background: white;
    padding: 20px;
    border-radius: 10px;
    max-height: 80%;
    overflow-y: auto;
  }

  #matchedFilesList {
    list-style: none;
    padding: 0;
