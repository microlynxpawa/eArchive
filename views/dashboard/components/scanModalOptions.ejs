<!-- Bootstrap Modal -->
<div class="modal fade" id="upgradeModal" tabindex="-1" aria-labelledby="upgradeModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content" style="width:100%">
      <div class="modal-header">
        <h5 class="modal-title" id="upgradeModalLabel">Upgrade Your Plan</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>
          This feature is only available on advanced plans. To upgrade, click the <b>Upgrade</b> button below to contact us  at info@microlynxe.com and request an upgrade by email. Or, click <b>Upload existing file</b> to continue by selecting a file from your device.
        </p>
        <div id="emailTemplateBox" style="display:none; margin-top:10px;">
          <label for="upgradeEmailTemplate" class="form-label">Email Template:</label>
          <textarea id="upgradeEmailTemplate" class="form-control" rows="7" readonly>
Subject: Request for Plan Upgrade

Hello Microlynxe Team,

I would like to upgrade my plan to access advanced features. Please provide me with the available options and next steps.

My details:
- Name: [Your Name]
- Organization: [Your Organization]
- Current Plan: [Your Current Plan]

Thank you.
          </textarea>
          <div class="mt-2">
            <a id="mailtoLink" href="#" class="btn btn-success" target="_blank">Send Email</a>
          </div>
        </div>
      </div>
      <div class="modal-footer row d-flex justify-content-between">
        <button type="button" class="btn btn-secondary col-5" id="cancelUpgrade" data-bs-dismiss="modal">Upload existing file</button>
        <button type="button" class="btn btn-primary col-5" id="upgradeButton">Upgrade</button>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Toast notification utility
  function showToast(message, type = 'success') {
    let toast = document.createElement('div');
    toast.className = 'custom-toast-notification ' + (type === 'success' ? 'toast-success' : 'toast-error');
    toast.innerText = message;
    toast.style.position = 'fixed';
    toast.style.bottom = '30px';
    toast.style.right = '30px';
    toast.style.background = type === 'success' ? '#22c55e' : '#dc3545';
    toast.style.color = '#fff';
    toast.style.padding = '16px 28px';
    toast.style.borderRadius = '8px';
    toast.style.fontSize = '1.1rem';
    toast.style.boxShadow = '0 2px 12px rgba(0,0,0,0.18)';
    toast.style.zIndex = 12000;
    document.body.appendChild(toast);
    setTimeout(() => { toast.remove(); }, 2500);
  }
  $(document).ready(function() {
    $("#upgradeButton").click(function() {
      $("#emailTemplateBox").slideDown();
      // Prepare mailto link with template
      const subject = encodeURIComponent("Request for Plan Upgrade");
      const body = encodeURIComponent(document.getElementById('upgradeEmailTemplate').value);
      $("#mailtoLink").attr("href", `mailto:info@microlynxe.com?subject=${subject}&body=${body}`);
    });
    $("#cancelUpgrade").click((event)=>{
      event.preventDefault();
      window.location.href = "scanFiles";
    });
  });
</script>
