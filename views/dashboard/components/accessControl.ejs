<style>
  /* Modal Overlay */
  #access-control-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    /* Transparent gray background */
    display: none;
    z-index: 1000;
    /* Ensure it appears above all other elements */
    justify-content: center;
    align-items: center;
  }

  /* Modal Content */
  #access-control-modal .modal-content {
    background: #f8fafc;
    border-radius: 14px;
    padding: 32px 28px;
    width: 600px;
    max-width: 98vw;
    box-shadow: 0 8px 32px rgba(30,41,59,0.18);
    border: 1px solid #e3e3e3;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    position: relative;
    margin: 0 auto;
  }

  /* Modal Title */
  #access-control-modal h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 18px;
    text-align: center;
  }

  /* Close Button */
  .close-button {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 24px;
    color: #333;
    cursor: pointer;
    background: none;
    border: none;
  }

  /* Input Field and Button Styling */
  #username-search-container {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
    gap: 8px;
  }

  #username-input {
    background: #fff;
    border: 1.5px solid #cbd5e1;
    color: #334155;
    font-size: 1.08rem;
    padding: 10px 12px;
    border-radius: 6px;
    transition: border 0.18s;
    width: calc(100% - 50px);
  }

  #username-input:focus {
    border: 1.5px solid #2563eb;
    outline: none;
  }

  #search-button, #open-all-users-modal {
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 10px 18px;
    font-size: 1.08rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.18s;
  }

  #search-button:hover, #open-all-users-modal:hover {
    background: #1d4ed8;
  }

  /* Permissions Section */
  #permissions-container {
    margin-top: 20px;
    background: #fff;
    border-radius: 8px;
    padding: 18px 16px 10px 16px;
    box-shadow: 0 2px 8px rgba(30,41,59,0.06);
  }

  .permission-item {
    margin-bottom: 10px;
    font-size: 1.08rem;
    color: #334155;
  }

  #update-permissions-button {
    margin-top: 18px;
    padding: 12px 0;
    font-size: 1.08rem;
    background: #22c55e;
    color: #fff;
    border: none;
    border-radius: 7px;
    cursor: pointer;
    font-weight: 600;
    letter-spacing: 0.01em;
    box-shadow: 0 2px 8px rgba(34,197,94,0.08);
    transition: background 0.18s;
    width: 100%;
  }

  #update-permissions-button:hover {
    background: #16a34a;
  }

  /* Confirm Modal */
  #access-control-confirm-modal {
    display: none;
    position: fixed;
    z-index: 3001;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.35);
    justify-content: center;
    align-items: center;
  }

  #access-control-confirm-modal .modal-content {
    background: #fff;
    border-radius: 8px;
    padding: 32px 28px;
    min-width: 320px;
    box-shadow: 0 8px 32px rgba(30, 41, 59, 0.18);
    text-align: center;
  }

  #access-control-confirm-modal .modal-content .modal-header {
    font-size: 1.15rem;
    color: #1e293b;
    margin-bottom: 18px;
    font-weight: 600;
  }

  #access-control-confirm-modal .modal-content .modal-footer {
    display: flex;
    gap: 18px;
    justify-content: center;
  }
</style>

<div id="access-control-modal">
  <div class="modal-content">
    <button class="close-button" id="close-access-control-modal">&times;</button>
    <h2>Access Control</h2>
    <div id="username-search-container">
      <input type="text" id="username-input" placeholder="Type username(s)" />
      <button id="search-button">🔍 Search</button>
      <button id="open-all-users-modal" type="button" style="margin-left:8px; padding:10px; font-size:16px; background:#558bf7; border:1px solid #3a5efd; border-radius:4px; cursor:pointer;">All Users</button>
    </div>
    <div id="user-info">
      <!-- This section will display the user information dynamically -->
    </div>
    <div id="permissions-container" style="display: none;">
      <p>Select or modify this user's permissions:</p>
      <label class="permission-item">
        <input type="checkbox" id="admin-rights" /> Admin Roles
      </label>
      <label class="permission-item">
        <input type="checkbox" id="supervisor-rights" /> Supervisor Roles
      </label>
      <label class="permission-item">
        <input type="checkbox" id="personnel-rights" /> User Roles
      </label>
      <button id="update-permissions-button" class="btn btn-success d-block mt-3">Update Permissions</button>
    </div>
  </div>
</div>

<!-- Confirm Modal -->
<div id="access-control-confirm-modal" style="display:none; position:fixed; z-index:3001; left:0; top:0; width:100vw; height:100vh; background:rgba(0,0,0,0.35); justify-content:center; align-items:center;">
  <div style="background:#fff; border-radius:8px; padding:32px 28px; min-width:320px; box-shadow:0 8px 32px rgba(30,41,59,0.18); text-align:center;">
    <div style="font-size:1.15rem; color:#1e293b; margin-bottom:18px; font-weight:600;">Are you sure you want to update permissions for all selected users?</div>
    <div style="display:flex; gap:18px; justify-content:center;">
      <button id="access-control-confirm-yes" class="btn btn-success">Yes</button>
      <button id="access-control-confirm-no" class="btn btn-secondary">No</button>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const accessControlModal = document.getElementById("access-control-modal");
    const closeAccessControlModal = document.getElementById("close-access-control-modal");
    const accessControlButton = document.getElementById("access-control-button");
    const searchButton = document.getElementById("search-button");
    const usernameInput = document.getElementById("username-input");
    const userInfo = document.getElementById("user-info");
    const permissionsContainer = document.getElementById("permissions-container");
    const updatePermissionsButton = document.getElementById("update-permissions-button");
    const editDepartmentModal = document.getElementById("edit-department-modal");
    const confirmModal = document.getElementById('access-control-confirm-modal');
    const confirmYes = document.getElementById('access-control-confirm-yes');
    const confirmNo = document.getElementById('access-control-confirm-no');

    const checkboxes = [
      document.getElementById("admin-rights"),
      document.getElementById("supervisor-rights"),
      document.getElementById("personnel-rights")
    ];

    let onConfirm = null;

    // Open Modal
    accessControlButton.addEventListener("click", (e) => {
      e.preventDefault();
      accessControlModal.style.display = "flex";
    });

    // Close Modal
    closeAccessControlModal.addEventListener("click", () => {
      accessControlModal.style.display = "none";
    });

    // Ensure Toast is always above modals
    const toastContainer = document.querySelector('.swal2-container, .swal2-toast');
    if (toastContainer) {
      toastContainer.style.zIndex = 3000;
    }

    // Fetch User Info
    searchButton.addEventListener("click", async () => {
      const username = usernameInput.value.trim();
      if (!username) {
        Toast.fire({icon:'error',title:'Please enter a username.'});
        return;
      }
      try {
        const response = await fetch(`/admin/searchUsers?usernames=${username}`);
        if (!response.ok) throw new Error("User not found.");
        const data = await response.json();
        userInfo.innerHTML = "";
        if (Array.isArray(data)) {
          data.forEach(user => {
            userInfo.innerHTML += `<p>Username: <strong>${user.username}</strong></p>`;
          });
        } else {
          userInfo.innerHTML = `<p>Username: <strong>${data.username}</strong></p>`;
        }
        permissionsContainer.style.display = "block";
      } catch (error) {
        Toast.fire({icon:'error',title:'Error: '+error.message});
      }
    });


    // Allow allUsersModal to set usernames in this modal
    window.setAccessControlUsernames = function(usernames) {
      usernameInput.value = usernames.join(', ');
      // Optionally, trigger a search automatically:
      searchButton.click();
    };

    // Open All Users Modal for Access Control
    document.getElementById('open-all-users-modal').addEventListener('click', function(e) {
      e.preventDefault();
      if (window.openAllUsersModal) {
        window.openAllUsersModal(function(usernames) {
          usernameInput.value = usernames.join(', ');
          searchButton.click();
        });
      }
    });

    // Ensure Only One Checkbox Can Be Checked
    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          checkboxes.forEach((otherCheckbox) => {
            if (otherCheckbox !== checkbox) {
              otherCheckbox.checked = false; // Uncheck other checkboxes
            }
          });
        }
      });
    });

    // Custom confirm modal logic
    function showConfirmModal(callback) {
      onConfirm = callback;
      confirmModal.style.display = 'flex';
    }
    confirmYes.onclick = function() {
      confirmModal.style.display = 'none';
      if (onConfirm) onConfirm();
    };
    confirmNo.onclick = function() {
      confirmModal.style.display = 'none';
    };

    // Update Permissions
    updatePermissionsButton.addEventListener("click", async () => {
      const username = usernameInput.value.trim();
      if (!username) {
        Toast.fire({icon:'error',title:'Please enter or select at least one username.'});
        return;
      }
      const usernames = username.split(',').map(u => u.trim()).filter(Boolean);
      if (usernames.length === 0) {
        Toast.fire({icon:'error',title:'No valid usernames selected.'});
        return;
      }
      const permissions = {
        admin: document.getElementById("admin-rights").checked,
        supervisor: document.getElementById("supervisor-rights").checked,
        personnel: document.getElementById("personnel-rights").checked,
      };
      showConfirmModal(async function() {
        try {
          const response = await fetch(`/admin/searchUsers/permissions?usernames=${encodeURIComponent(usernames.join(','))}`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(permissions),
            }
          );
          if (!response.ok) throw new Error("Failed to update permissions.");
          Toast.fire({icon:'success',title:'Permissions updated successfully for all selected users.'});
          accessControlModal.style.display = "none";
        } catch (error) {
          Toast.fire({icon:'error',title:'Error: '+error.message});
        }
      });
    });
  });
</script>