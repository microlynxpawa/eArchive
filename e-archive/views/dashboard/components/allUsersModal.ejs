<style>
  #all-users-modal {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    background: rgba(30, 41, 59, 0.45);
    display: none;
    z-index: 1100;
    justify-content: center;
    align-items: center;
  }
  .all-users-modal-content {
    background: #f8fafc;
    border-radius: 14px;
    padding: 32px 28px 20px 28px;
    width: 480px;
    max-width: 95vw;
    box-shadow: 0 8px 32px rgba(30,41,59,0.18);
    border: 1px solid #e3e3e3;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    position: relative;
  }
  .close-all-users-modal {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 22px;
    color: #64748b;
    cursor: pointer;
    background: none;
    border: none;
    transition: color 0.15s;
  }
  .close-all-users-modal:hover {
    color: #1e293b;
  }
  #users-list {
    background: #fff;
    border-radius: 8px;
    padding: 10px 8px;
    margin-bottom: 18px;
    border: 1px solid #e2e8f0;
    max-height: 340px;
    overflow-y: auto;
    box-shadow: 0 2px 8px rgba(30,41,59,0.06);
  }
  .user-list-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 0;
    border-bottom: 1px solid #e5e7eb;
    font-size: 1.08rem;
    color: #334155;
    border-radius: 4px;
    transition: background 0.15s;
    cursor: pointer;
  }
  .user-list-item:last-child {
    border-bottom: none;
  }
  .user-list-item:hover {
    background: #e0e7ef;
  }
  .user-checkbox {
    accent-color: #2563eb;
    width: 18px;
    height: 18px;
  }
  #select-users-ok {
    margin-top: 10px;
    padding: 12px 0;
    font-size: 1.08rem;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 7px;
    cursor: pointer;
    font-weight: 600;
    letter-spacing: 0.01em;
    box-shadow: 0 2px 8px rgba(34,197,94,0.08);
    transition: background 0.18s;
    width: 100%;
  }
  #select-users-ok:hover {
    background: #1d4ed8;
  }
</style>

<div id="all-users-modal">
  <div class="all-users-modal-content">
    <button class="close-all-users-modal" id="close-all-users-modal">&times;</button>
    <h2 style="font-size:1.3rem; font-weight:700; color:#1e293b; margin-bottom:10px;">Select Users</h2>
    <div id="users-list">
      <!-- User checkboxes will be loaded here -->
    </div>
    <button id="select-users-ok">OK</button>
  </div>
</div>

<script>
(function() {
  // Open All Users Modal from Access Control
  const openAllUsersBtn = document.getElementById('open-all-users-modal');
  const allUsersModal = document.getElementById('all-users-modal');
  const closeAllUsersModal = document.getElementById('close-all-users-modal');
  const usersList = document.getElementById('users-list');
  const selectUsersOk = document.getElementById('select-users-ok');

  // Store selected usernames
  let selectedUsernames = [];

  // --- Modal callback logic ---
  let allUsersCallback = null;
  window.openAllUsersModal = function(callback) {
    allUsersCallback = callback;
    allUsersModal.style.display = 'flex';
    usersList.innerHTML = '<em>Loading users...</em>';
    fetch('/admin/retrieve-users')
      .then(res => res.json())
      .then(data => {
        if (data && data.records && Array.isArray(data.records)) {
          usersList.innerHTML = data.records.map(user => {
            let role = 'User';
            if (user.permissions && typeof user.permissions === 'object' && !Array.isArray(user.permissions)) {
              // permissions is an object with true/false fields
              if (user.permissions.is_admin || user.permissions.isAdmin) {
                role = 'Admin';
              } else if (user.permissions.supervision_right || user.permissions.supervisor_right) {
                role = 'Supervisor';
              }
            } else if (Array.isArray(user.permissions)) {
              // permissions is an array
              if (user.permissions.includes('is_admin') || user.permissions.includes('isAdmin')) {
                role = 'Admin';
              } else if (user.permissions.includes('supervision_right') || user.permissions.includes('supervisor_right')) {
                role = 'Supervisor';
              }
            }
            return `<div class="user-list-item">
              <input type="checkbox" class="user-checkbox" value="${user.username}" id="user-${user.username}">
              <label for="user-${user.username}">${user.username} <span style='color:#888;font-size:0.95em;'>(${role})</span></label>
            </div>`;
          }).join('');
          enableRowClickSelection();
        } else {
          usersList.innerHTML = '<em>No users found.</em>';
        }
      })
      .catch(() => {
        usersList.innerHTML = '<em>Error loading users.</em>';
      });
  };

  // Remove old event binding if present
  if (openAllUsersBtn) {
    openAllUsersBtn.onclick = window.openAllUsersModal;
  }

  // Close modal
  closeAllUsersModal.addEventListener('click', function() {
    allUsersModal.style.display = 'none';
  });

  // Ensure Toast is always above modals
  setTimeout(() => {
    const toastContainer = document.querySelector('.swal2-container, .swal2-toast');
    if (toastContainer) toastContainer.style.zIndex = 3000;
  }, 10);

  // OK button: collect selected users and pass to callback
  selectUsersOk.addEventListener('click', function() {
    selectedUsernames = Array.from(document.querySelectorAll('.user-checkbox:checked')).map(cb => cb.value);
    if (selectedUsernames.length === 0) {
      Toast.fire({icon:'error',title:'Select at least one user.'});
      return;
    }
    allUsersModal.style.display = 'none';
    if (typeof allUsersCallback === 'function') {
      allUsersCallback(selectedUsernames);
    }
  });

  // Drag-to-select logic for user checkboxes
  let isDragging = false;
  let dragStartY = 0;
  let dragEndY = 0;
  let dragStartIndex = null;
  let dragEndIndex = null;
  let userCheckboxes = [];

  function getCheckboxIndexFromY(y) {
    for (let i = 0; i < userCheckboxes.length; i++) {
      const rect = userCheckboxes[i].getBoundingClientRect();
      if (y >= rect.top && y <= rect.bottom) return i;
    }
    return null;
  }

  usersList.addEventListener('mousedown', function(e) {
    // Only start drag-to-select if NOT clicking a checkbox
    if (!e.target.classList.contains('user-checkbox')) {
      isDragging = true;
      userCheckboxes = Array.from(document.querySelectorAll('.user-checkbox'));
      dragStartY = e.clientY;
      dragStartIndex = getCheckboxIndexFromY(dragStartY);
      if (dragStartIndex !== null) userCheckboxes[dragStartIndex].checked = !userCheckboxes[dragStartIndex].checked;
      e.preventDefault();
    }
  });
  usersList.addEventListener('mousemove', function(e) {
    if (isDragging) {
      dragEndY = e.clientY;
      dragEndIndex = getCheckboxIndexFromY(dragEndY);
      if (dragStartIndex !== null && dragEndIndex !== null) {
        const [start, end] = [dragStartIndex, dragEndIndex].sort((a, b) => a - b);
        userCheckboxes.forEach((cb, i) => {
          cb.checked = (i >= start && i <= end);
        });
      }
    }
  });
  document.addEventListener('mouseup', function() {
    isDragging = false;
    dragStartIndex = null;
    dragEndIndex = null;
  });

  // After rendering users, add click event to each row for toggling
  function enableRowClickSelection() {
    usersList.querySelectorAll('.user-list-item').forEach(row => {
      row.addEventListener('click', function(e) {
        // Only toggle if not clicking directly on the checkbox
        if (!e.target.classList.contains('user-checkbox')) {
          const cb = row.querySelector('.user-checkbox');
          cb.checked = !cb.checked;
        }
      });
      // Prevent row click from firing when clicking checkbox directly
      row.querySelector('.user-checkbox').addEventListener('click', function(e) {
        e.stopPropagation();
      });
    });
  }
})();
</script>
